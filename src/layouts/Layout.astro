---
import '../styles/global.css'

interface Props {
  title: string
  description?: string
}

const { title, description = 'Twin Cities real estate expert serving Minneapolis, Saint Paul, and surrounding communities.' } = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | The Sawicki Group</title>
  </head>
  <body class="bg-white text-stone-800 font-sans antialiased">

    <!-- NAV -->
    <header class="border-b border-stone-200">
      <nav class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="text-xl font-semibold tracking-tight text-stone-900">
          The Sawicki Group
        </a>
        <div class="flex items-center gap-8 text-sm text-stone-600">
          <a href="/search" class="hover:text-stone-900 transition-colors">Search</a>
          <a href="/blog" class="hover:text-stone-900 transition-colors">Market Updates</a>
          <a href="/about" class="hover:text-stone-900 transition-colors">About</a>
          <a href="/contact" class="bg-stone-900 text-white px-4 py-2 rounded-lg hover:bg-stone-700 transition-colors">
            Contact
          </a>
        </div>
      </nav>
    </header>

    <!-- PAGE CONTENT -->
    <main>
      <slot />
    </main>

    <!-- FOOTER -->
    <footer class="border-t border-stone-200 mt-24">
      <div class="max-w-6xl mx-auto px-6 py-12 grid grid-cols-3 gap-8 text-sm text-stone-500">
        <div>
          <div class="font-semibold text-stone-900 mb-3">The Sawicki Group</div>
          <div>Coldwell Banker Realty</div>
          <div>Twin Cities, Minnesota</div>
        </div>
        <div>
          <div class="font-semibold text-stone-900 mb-3">Navigate</div>
          <div class="flex flex-col gap-2">
            <a href="/search" class="hover:text-stone-900 transition-colors">Search Homes</a>
            <a href="/blog" class="hover:text-stone-900 transition-colors">Market Updates</a>
            <a href="/about" class="hover:text-stone-900 transition-colors">About</a>
            <a href="/contact" class="hover:text-stone-900 transition-colors">Contact</a>
          </div>
        </div>
        <div>
          <div class="font-semibold text-stone-900 mb-3">Legal</div>
          <div class="flex flex-col gap-2">
            <span>Licensed in Minnesota</span>
            <span>© {new Date().getFullYear()} The Sawicki Group</span>
            <span>All rights reserved</span>
          </div>
        </div>
      </div>
    </footer>

  </body>
</html>