---
import Layout from '../../layouts/Layout.astro'
import { getCollection, render } from 'astro:content'

export const prerender = true

export async function getStaticPaths() {
  const posts = await getCollection('blog')
  return posts.map(post => ({
    params: { id: post.id },
    props: { post },
  }))
}

const { post } = Astro.props
if (!post) return Astro.redirect('/blog')
const { Content } = await render(post)
---

<Layout title={post.data.title} description={post.data.excerpt}>

  <article class="max-w-3xl mx-auto px-6 py-20">

    <div class="mb-12">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-xs font-semibold text-amber-700 uppercase tracking-widest">
          {post.data.tag}
        </span>
        {post.data.author === 'AI' && (
          <span class="text-xs bg-stone-100 text-stone-500 px-2 py-0.5 rounded-full">
            AI generated
          </span>
        )}
      </div>
      <h1 class="text-4xl font-semibold text-stone-900 leading-tight mb-4">
        {post.data.title}
      </h1>
      <div class="flex items-center gap-4 text-sm text-stone-400">
        <span>
          {post.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
        </span>
        <span>By {post.data.author === 'AI' ? 'The Sawicki Group AI' : post.data.author}</span>
      </div>
    </div>

    <div class="prose prose-stone prose-lg max-w-none
                prose-headings:font-semibold prose-headings:text-stone-900
                prose-p:text-stone-600 prose-p:leading-relaxed
                prose-a:text-amber-700 prose-a:no-underline hover:prose-a:underline
                prose-strong:text-stone-900">
      <Content />
    </div>

    <div class="mt-16 pt-8 border-t border-stone-200 flex items-center justify-between">
      <a href="/blog" class="text-sm text-stone-500 hover:text-stone-900 transition-colors">
        ← All posts
      </a>
      <a href="/contact" class="bg-stone-900 text-white px-5 py-2.5 rounded-lg text-sm font-medium hover:bg-stone-700 transition-colors">
        Talk to Jim
      </a>
    </div>

  </article>

</Layout>