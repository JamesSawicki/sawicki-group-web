---
import Layout from '../../layouts/Layout.astro'

const posts = [
  {
    slug: 'spring-inventory-2026',
    title: 'Spring inventory is up — what that means for buyers',
    date: 'May 1, 2026',
    tag: 'Buyers',
    excerpt: 'After a historically tight winter, Twin Cities inventory is finally moving. Here is what the data shows and how to position yourself as a buyer right now.',
  },
  {
    slug: 'crocus-hill-q1-2026',
    title: 'Crocus Hill market report: Q1 2026',
    date: 'April 15, 2026',
    tag: 'Market Data',
    excerpt: 'Days on market, median price, and list-to-sale ratio for one of Saint Paul\'s most consistently competitive neighborhoods.',
  },
  {
    slug: 'fed-rate-update-april-2026',
    title: 'Rate update: how the latest Fed decision affects your purchase power',
    date: 'April 3, 2026',
    tag: 'Rates',
    excerpt: 'The Fed held rates steady again. What that means for mortgage rates, affordability, and whether now is still a reasonable time to buy.',
  },
]
---

<Layout title="Market Updates" description="Twin Cities real estate market updates, neighborhood reports, and homebuying guides from The Sawicki Group.">

  <section class="max-w-4xl mx-auto px-6 py-20">

    <p class="text-sm font-semibold text-amber-700 uppercase tracking-widest mb-4">Blog</p>
    <h1 class="text-4xl font-semibold text-stone-900 mb-4">Market Updates</h1>
    <p class="text-stone-500 text-lg mb-16">
      Straight talk on what's happening in the Twin Cities market.
    </p>

    <div class="flex flex-col gap-8">
      {posts.map(post => (
        <article class="border border-stone-200 rounded-xl p-8 hover:border-stone-400 transition-colors">
          <div class="text-xs font-semibold text-amber-700 uppercase tracking-widest mb-3">{post.tag}</div>
          <h2 class="text-xl font-semibold text-stone-900 mb-3">
            <a href={`/blog/${post.slug}`} class="hover:text-stone-600 transition-colors">
              {post.title}
            </a>
          </h2>
          <p class="text-stone-500 text-sm leading-relaxed mb-4">{post.excerpt}</p>
          <div class="text-xs text-stone-400">{post.date}</div>
        </article>
      ))}
    </div>

  </section>

</Layout>