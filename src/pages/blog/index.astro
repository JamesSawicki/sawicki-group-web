---
import Layout from '../../layouts/Layout.astro'
import { getCollection } from 'astro:content'

const posts = (await getCollection('blog'))
  .filter((post: any) => !post.data.draft)
  .sort((a: any, b: any) => b.data.date.valueOf() - a.data.date.valueOf())
---

<Layout 
  title="Market Updates" 
  description="Twin Cities real estate market updates, neighborhood reports, and homebuying guides from The Sawicki Group."
>
  <section class="max-w-4xl mx-auto px-6 py-20">

    <p class="text-sm font-semibold text-amber-700 uppercase tracking-widest mb-4">Blog</p>
    <h1 class="text-4xl font-semibold text-stone-900 mb-4">Market Updates</h1>
    <p class="text-stone-500 text-lg mb-16">
      Straight talk on what's happening in the Twin Cities market.
    </p>

    <div class="flex flex-col gap-8">
      {posts.map((post: any) => (
        <article class="border border-stone-200 rounded-xl p-8 hover:border-stone-400 transition-colors">
          <div class="flex items-center gap-3 mb-3">
            <span class="text-xs font-semibold text-amber-700 uppercase tracking-widest">
              {post.data.tag}
            </span>
            {post.data.author === 'AI' && (
              <span class="text-xs bg-stone-100 text-stone-500 px-2 py-0.5 rounded-full">
                AI generated
              </span>
            )}
          </div>
          <h2 class="text-xl font-semibold text-stone-900 mb-3">
            <a href={`/blog/${post.id}`} class="hover:text-stone-600 transition-colors">
              {post.data.title}
            </a>
          </h2>
          <p class="text-stone-500 text-sm leading-relaxed mb-4">{post.data.excerpt}</p>
          <div class="flex items-center gap-4 text-xs text-stone-400">
            <span>{post.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
            <span>By {post.data.author === 'AI' ? 'The Sawicki Group AI' : post.data.author}</span>
          </div>
        </article>
      ))}
    </div>

  </section>
</Layout>