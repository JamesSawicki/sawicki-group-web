---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Contact" description="Get in touch with Jim Sawicki at The Sawicki Group, Coldwell Banker Realty.">

  <section class="max-w-3xl mx-auto px-6 py-20">

    <p class="text-sm font-semibold text-amber-700 uppercase tracking-widest mb-4">Contact</p>
    <h1 class="text-4xl font-semibold text-stone-900 mb-4">Let's talk</h1>
    <p class="text-stone-500 text-lg mb-12">
      No pressure, no scripts. Just a straightforward conversation about what you're looking for.
    </p>

    <div class="grid grid-cols-2 gap-16">

      <!-- FORM -->
      <div>
        <!-- Success message — hidden by default -->
        <div id="success" class="hidden mb-6 p-4 bg-green-50 border border-green-200 rounded-lg text-sm text-green-800">
          Message sent. I'll be in touch within a few hours.
        </div>

        <!-- Error message — hidden by default -->
        <div id="error" class="hidden mb-6 p-4 bg-red-50 border border-red-200 rounded-lg text-sm text-red-800">
          Something went wrong. Please try again or email me directly.
        </div>

        <form id="contact-form" class="flex flex-col gap-5">
          <div class="flex flex-col gap-2">
            <label class="text-sm font-medium text-stone-700">Name <span class="text-red-400">*</span></label>
            <input
              type="text"
              name="name"
              required
              placeholder="Your name"
              class="border border-stone-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-stone-500"
            />
          </div>
          <div class="flex flex-col gap-2">
            <label class="text-sm font-medium text-stone-700">Email <span class="text-red-400">*</span></label>
            <input
              type="email"
              name="email"
              required
              placeholder="your@email.com"
              class="border border-stone-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-stone-500"
            />
          </div>
          <div class="flex flex-col gap-2">
            <label class="text-sm font-medium text-stone-700">Phone (optional)</label>
            <input
              type="tel"
              name="phone"
              placeholder="(612) 555-0000"
              class="border border-stone-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-stone-500"
            />
          </div>
          <div class="flex flex-col gap-2">
            <label class="text-sm font-medium text-stone-700">What are you looking to do?</label>
            <select
              name="intent"
              class="border border-stone-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-stone-500 text-stone-600"
            >
              <option value="">Select one</option>
              <option>Buy a home</option>
              <option>Sell a home</option>
              <option>Buy and sell</option>
              <option>Just exploring</option>
            </select>
          </div>
          <div class="flex flex-col gap-2">
            <label class="text-sm font-medium text-stone-700">Message <span class="text-red-400">*</span></label>
            <textarea
              name="message"
              required
              rows="4"
              placeholder="Tell me a bit about what you're looking for..."
              class="border border-stone-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-stone-500 resize-none"
            />
          </div>
          <button
            type="submit"
            id="submit-btn"
            class="bg-stone-900 text-white px-6 py-3 rounded-lg hover:bg-stone-700 transition-colors font-medium text-sm"
          >
            Send Message
          </button>
        </form>
      </div>

      <!-- CONTACT DETAILS -->
      <div class="flex flex-col gap-8 text-sm text-stone-600">
        <div>
          <div class="font-semibold text-stone-900 mb-2">Response time</div>
          <p class="leading-relaxed">
            I respond to all inquiries within a few hours during business hours.
            For urgent matters, call or text directly.
          </p>
        </div>
        <div>
          <div class="font-semibold text-stone-900 mb-2">Phone / Text</div>
          <p>Add your number here</p>
        </div>
        <div>
          <div class="font-semibold text-stone-900 mb-2">Email</div>
          <p>jamesvsawicki@gmail.com</p>
        </div>
        <div>
          <div class="font-semibold text-stone-900 mb-2">Brokerage</div>
          <p class="leading-relaxed">
            Coldwell Banker Realty<br />
            Twin Cities, Minnesota
          </p>
        </div>
      </div>

    </div>
  </section>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement
    const successMsg = document.getElementById('success') as HTMLDivElement
    const errorMsg = document.getElementById('error') as HTMLDivElement

    form.addEventListener('submit', async (e) => {
      e.preventDefault()

      // Hide any previous messages
      successMsg.classList.add('hidden')
      errorMsg.classList.add('hidden')

      // Disable button while submitting
      submitBtn.disabled = true
      submitBtn.textContent = 'Sending...'

      try {
        const formData = new FormData(form)

        const response = await fetch('/api/contact', {
          method: 'POST',
          body: formData
        })

        const result = await response.json()

        if (result.success) {
          successMsg.classList.remove('hidden')
          form.reset()
        } else {
          errorMsg.textContent = result.error || 'Something went wrong. Please try again.'
          errorMsg.classList.remove('hidden')
        }

      } catch {
        errorMsg.classList.remove('hidden')
      } finally {
        submitBtn.disabled = false
        submitBtn.textContent = 'Send Message'
      }
    })
  </script>

</Layout>