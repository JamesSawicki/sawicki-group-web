---
import Layout from "../../layouts/Layout.astro";
import type { Listing } from "../../types/listing";  

const apiBase = import.meta.env.PUBLIC_API_BASE_URL;

let listings: Listing[] = [];
let error = false;

try {
  const res = await fetch(`${apiBase}/api/listings`);
  if (res.ok) {
    listings = await res.json();
  } else {
    error = true;
  }
} catch (e) {
  error = true;
}
---

<Layout
  title="Current Listings"
  description="Browse current Twin Cities home listings from The Sawicki Group. Minneapolis, Saint Paul, and surrounding communities."
>
  <div class="max-w-6xl mx-auto px-6 py-16">
    <div class="mb-10">
      <h1 class="text-3xl font-semibold text-stone-900 mb-2">Current Listings</h1>
      <p class="text-stone-500">
        Homes represented by The Sawicki Group. Contact us for showings or questions.
      </p>
    </div>

    {error && (
      <p class="text-stone-500">
        Unable to load listings at this time. Please try again shortly or{" "}
        <a href="/contact" class="underline hover:text-stone-900">contact us directly</a>.
      </p>
    )}

    {!error && listings.length === 0 && (
      <p class="text-stone-500">No active listings at this time. Check back soon.</p>
    )}

   <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
  {listings.map((listing) => (
    <a href={`/listings/${listing.id}`}
      class="group border border-stone-200 rounded-xl p-6 hover:border-stone-400 hover:shadow-sm transition-all"
    >
      <div class="flex items-start justify-between mb-3">
        <div>
          <div class="font-semibold text-stone-900 group-hover:underline">
            {listing.address}
          </div>
          <div class="text-sm text-stone-500">{listing.cityStateZip}</div>
        </div>
        <div class="text-lg font-semibold text-stone-900 shrink-0 ml-4">
          {listing.price}
        </div>
      </div>

      {listing.neighborhood && (
        <div class="text-xs text-stone-400 uppercase tracking-wide mb-3">
          {listing.neighborhood}
        </div>
      )}

      <div class="flex gap-4 text-sm text-stone-600 mb-3">
        {listing.beds && <span>{listing.beds} bed</span>}
        {listing.baths && <span>{listing.baths} bath</span>}
        {listing.sqft && <span>{listing.sqft} sqft</span>}
        {listing.style && <span>· {listing.style}</span>}
      </div>

      {listing.description && (
        <p class="text-sm text-stone-500 line-clamp-2">{listing.description}</p>
      )}

      <div class="mt-4 text-sm font-medium text-stone-900 group-hover:underline">
        View property →
      </div>
    </a>
  ))}
</div>
  </div>
</Layout>