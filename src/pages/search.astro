---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Search Homes" description="Search homes for sale in Minneapolis, Saint Paul, and the Twin Cities.">

  <section class="max-w-6xl mx-auto px-6 py-20">

    <p class="text-sm font-semibold text-amber-700 uppercase tracking-widest mb-4">Search</p>
    <h1 class="text-4xl font-semibold text-stone-900 mb-4">Find your next home</h1>
    <p class="text-stone-500 text-lg mb-12">
      Full MLS search with live Twin Cities listings coming soon. 
      In the meantime, tell me what you're looking for and I'll send you matching properties directly.
    </p>

    <div class="border border-stone-200 rounded-2xl p-10 text-center max-w-lg mx-auto">
      <div class="text-3xl mb-4">🔍</div>
      <div class="font-semibold text-stone-900 mb-2">Search launching soon</div>
      <p class="text-sm text-stone-500 mb-6">
        Get notified when live search goes live, or contact me now for a custom property search.
      </p>
      <a href="/contact" class="bg-stone-900 text-white px-6 py-3 rounded-lg hover:bg-stone-700 transition-colors font-medium text-sm">
        Request a Custom Search
      </a>
    </div>

  </section>

</Layout>