---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Home" description="Find your next home in Minneapolis, Saint Paul, and the Twin Cities with The Sawicki Group.">

  <!-- HERO -->
  <section class="bg-stone-50 border-b border-stone-200">
    <div class="max-w-6xl mx-auto px-6 py-24">
      <div class="max-w-2xl">
        <p class="text-sm font-semibold text-amber-700 uppercase tracking-widest mb-4">
          Twin Cities Real Estate
        </p>
        <h1 class="text-5xl font-semibold text-stone-900 leading-tight mb-6">
          Find your place in Minneapolis & Saint Paul
        </h1>
        <p class="text-lg text-stone-500 mb-10 leading-relaxed">
          Local expertise, honest guidance, and a process built around you. 
          The Sawicki Group has helped Twin Cities buyers and sellers navigate 
          one of the Midwest's most competitive markets.
        </p>
        <div class="flex gap-4">
          <a href="/search" class="bg-stone-900 text-white px-6 py-3 rounded-lg hover:bg-stone-700 transition-colors font-medium">
            Search Homes
          </a>
          <a href="/contact" class="border border-stone-300 text-stone-700 px-6 py-3 rounded-lg hover:border-stone-500 transition-colors font-medium">
            Get in Touch
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- NEIGHBORHOODS -->
  <section class="max-w-6xl mx-auto px-6 py-20">
    <h2 class="text-2xl font-semibold text-stone-900 mb-2">Explore Neighborhoods</h2>
    <p class="text-stone-500 mb-10">Deep local knowledge across the metro.</p>
    <div class="grid grid-cols-3 gap-6">
      {[
        { name: 'Crocus Hill', city: 'Saint Paul', desc: 'Victorian charm, Grand Ave walkability, top-rated schools.' },
        { name: 'Mac-Groveland', city: 'Saint Paul', desc: 'Tree-lined streets, Randolph Ave dining, classic architecture.' },
        { name: 'Linden Hills', city: 'Minneapolis', desc: 'Lake access, village feel, strong community character.' },
        { name: 'Northeast Minneapolis', city: 'Minneapolis', desc: 'Arts district, breweries, rapidly appreciating market.' },
        { name: 'Edina', city: 'Suburb', desc: '50th & France retail, top schools, consistent demand.' },
        { name: 'Highland Park', city: 'Saint Paul', desc: 'Ford site redevelopment, river views, walkable core.' },
      ].map(n => (
        <div class="border border-stone-200 rounded-xl p-6 hover:border-stone-400 transition-colors cursor-pointer">
          <div class="text-xs font-semibold text-amber-700 uppercase tracking-widest mb-2">{n.city}</div>
          <div class="font-semibold text-stone-900 mb-2">{n.name}</div>
          <div class="text-sm text-stone-500 leading-relaxed">{n.desc}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- VALUE PROPS -->
  <section class="bg-stone-50 border-y border-stone-200">
    <div class="max-w-6xl mx-auto px-6 py-20 grid grid-cols-3 gap-12">
      {[
        { heading: 'Local First', body: 'Born and raised in the Twin Cities. Every neighborhood recommendation comes from real experience, not a map.' },
        { heading: 'Full Transparency', body: 'No pressure, no games. You get honest market data and straight talk at every step of the process.' },
        { heading: 'Tech-Forward', body: 'AI-powered listing assistants, instant market alerts, and tools that keep you ahead in a fast-moving market.' },
      ].map(v => (
        <div>
          <div class="font-semibold text-stone-900 mb-3">{v.heading}</div>
          <div class="text-sm text-stone-500 leading-relaxed">{v.body}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- BLOG PREVIEW -->
  <section class="max-w-6xl mx-auto px-6 py-20">
    <div class="flex items-end justify-between mb-10">
      <div>
        <h2 class="text-2xl font-semibold text-stone-900 mb-2">Market Updates</h2>
        <p class="text-stone-500">What's happening in the Twin Cities market right now.</p>
      </div>
      <a href="/blog" class="text-sm text-amber-700 font-medium hover:text-amber-900 transition-colors">
        View all posts →
      </a>
    </div>
    <div class="grid grid-cols-3 gap-6">
      {[
        { title: 'Spring inventory is up — what that means for buyers', date: 'May 1, 2026', tag: 'Buyers' },
        { title: 'Crocus Hill market report: Q1 2026', date: 'April 15, 2026', tag: 'Market Data' },
        { title: 'Rate update: how the latest Fed decision affects your purchase power', date: 'April 3, 2026', tag: 'Rates' },
      ].map(post => (
        <div class="border border-stone-200 rounded-xl p-6 hover:border-stone-400 transition-colors cursor-pointer">
          <div class="text-xs font-semibold text-amber-700 uppercase tracking-widest mb-3">{post.tag}</div>
          <div class="font-semibold text-stone-900 leading-snug mb-4">{post.title}</div>
          <div class="text-xs text-stone-400">{post.date}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-6xl mx-auto px-6 pb-24">
    <div class="bg-stone-900 rounded-2xl p-12 text-center">
      <h2 class="text-3xl font-semibold text-white mb-4">Ready to make a move?</h2>
      <p class="text-stone-400 mb-8 max-w-lg mx-auto">
        Whether you're buying your first home or selling after twenty years, 
        let's start with a conversation.
      </p>
      <a href="/contact" class="bg-white text-stone-900 px-8 py-3 rounded-lg font-medium hover:bg-stone-100 transition-colors">
        Schedule a Call
      </a>
    </div>
  </section>

</Layout>